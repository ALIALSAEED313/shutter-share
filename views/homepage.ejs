<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Shutter Share</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="page-shell">
        <%- include('./partials/navbar') %>

        <section class="hero">
            <p class="eyebrow">Curated community photography</p>
            <h1>Let every image tell a story.</h1>
            <p>Discover striking work from photographers around the world, leave feedback, and share your own visual perspective.</p>
            <div class="hero-actions">
                <a class="button button-primary" href="/photos/new">Upload a photo</a>
                <a class="button button-secondary" href="/auth/sign-up">Join the community</a>
            </div>
        </section>

        <div class="gallery-header">
            <h2>Featured gallery</h2>
        </div>

        <div class="gallery-grid">
            <% if (photos && photos.length > 0) { %>
                <% photos.forEach(photo => { %>
                    <article class="photo-card">
                        <a class="photo-card__link-area" href="/photos/<%= photo._id %>">
                            <img src="<%= photo.imageUrl %>" alt="<%= photo.title %>">
                            <div class="photo-card__content">
                                <h3><%= photo.title %></h3>
                                <p class="photo-card__meta">By <%= photo.ownerId ? photo.ownerId.profileName : 'Unknown' %></p>
                            </div>
                        </a>
                    </article>
                <% }) %>
            <% } else { %>
                <p class="empty-state">No public photos yet. Be the first to share a moment.</p>
            <% } %>
        </div>
    </div>
</body>
</html>