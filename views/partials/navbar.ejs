<nav class="site-header">
    <a class="brand" href="/">Shutter Share</a>
    <div class="nav-links">
        <a href="/">Gallery</a>
        <% if (user){ %>
        <a href="/photos/new">Upload</a>
        <a href="/photos/my-gallery">My Gallery</a>
        <a href="/auth/sign-out">Logout</a>
        <% } else{ %>
        <a href="/auth/sign-up">Sign up</a>
        <a href="/auth/sign-in">Login</a>
        <% } %>
        <button type="button" class="theme-toggle" id="themeToggle" aria-label="Toggle color theme">☀️</button>
    </div>
</nav>

<script>
  const toggleButton = document.getElementById('themeToggle');
  const root = document.documentElement;

  const applyTheme = (theme) => {
    root.setAttribute('data-theme', theme);
    if (toggleButton) {
      toggleButton.textContent = theme === 'light' ? '🌙' : '☀️';
    }
  };

  const savedTheme = localStorage.getItem('shutter-theme') || 'dark';
  applyTheme(savedTheme);

  if (toggleButton) {
    toggleButton.addEventListener('click', () => {
      const nextTheme = root.getAttribute('data-theme') === 'light' ? 'dark' : 'light';
      localStorage.setItem('shutter-theme', nextTheme);
      applyTheme(nextTheme);
    });
  }
</script>