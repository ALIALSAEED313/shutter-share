<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Gallery - ShutterShare</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="page-shell">
        <%- include('../partials/navbar.ejs') %>

        <section class="hero">
            <p class="eyebrow">Your portfolio</p>
            <h1>My Gallery</h1>
            <p>Review the collection of photos you’ve shared and select any image to see its full details.</p>
        </section>

        <div class="gallery-grid">
            <% if (photos && photos.length > 0) { %>
                <% photos.forEach(photo => { %>
                    <article class="photo-card">
                        <a class="photo-card__link-area" href="/photos/<%= photo._id %>">
                            <img src="<%= photo.imageUrl %>" alt="<%= photo.title %>">
                            <div class="photo-card__content">
                                <h3><%= photo.title %></h3>
                                <p class="photo-card__meta">Status: <%= photo.visibility %></p>
                            </div>
                        </a>
                    </article>
                <% }) %>
            <% } else { %>
                <div class="empty-state-card">
                    <p class="eyebrow">No photos yet</p>
                    <h3>Your gallery is waiting for its first frame</h3>
                    <p>Upload a few photos to start building your portfolio and share your work with the community.</p>
                    <a class="button button-primary" href="/photos/new">Upload your first photo</a>
                </div>
            <% } %>
        </div>
    </div>
</body>
</html>