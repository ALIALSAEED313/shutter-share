<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Upload Photo - ShutterShare</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="page-shell">
        <%- include('../partials/navbar.ejs') %>

        <main class="panel" style="margin-top: 1rem;">
            <h1>Upload a new photograph</h1>
            <p>Share your latest frame with a polished presentation that highlights the story behind the shot.</p>

            <form action="/photos" method="POST" enctype="multipart/form-data" class="form-grid" style="margin-top: 1rem;">
                <div class="field">
                    <label for="image">Select image</label>
                    <input type="file" name="image" id="image" accept="image/*" required>
                </div>

                <div class="field">
                    <label for="title">Title</label>
                    <input type="text" name="title" id="title" placeholder="Golden hour portrait" required>
                </div>

                <div class="field">
                    <label for="description">Story / description</label>
                    <textarea name="description" id="description" placeholder="Describe the mood, setting, or creative intent behind the image."></textarea>
                </div>

                <div class="field">
                    <label for="cameraSettings">Camera settings</label>
                    <input type="text" name="cameraSettings" id="cameraSettings" placeholder="e.g. f/1.8 · ISO 100 · 1/200s">
                </div>

                <div class="field">
                    <label>Visibility</label>
                    <div class="radio-group">
                        <label><input type="radio" name="visibility" value="public" checked> Public</label>
                        <label><input type="radio" name="visibility" value="private"> Private</label>
                    </div>
                </div>

                <button type="submit">Publish to gallery</button>
            </form>
        </main>
    </div>
</body>
</html>